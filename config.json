        }
    ],
    "channels": {
        "telegram": {
            "enabled": true,
            "token": "YOUR_TELEGRAM_BOT_TOKEN",
            "allow_from": [
                "YOUR_TELEGRAM_USER_ID"
            ]
        }
    },
    "gateway": {
        "host": "0.0.0.0",
        "port": 3002,
        "hot_reload": false
    },
    "tools": {
        "filter_sensitive_data": true,
        "filter_min_length": 8,
        "web": {
            "enabled": true,
            "duckduckgo": {
                "enabled": true,
                "max_results": 1
            }
        },
        "exec": {
            "enabled": true,
            "allow_remote": false,
            "enable_deny_patterns": false,
            "custom_allow_patterns": [
                "rclone copy *",
                "rclone mkdir *",
                "rclone ls *",
                "curl -s https://api.meshy.ai/*",
                "curl -s -X POST https://api.meshy.ai/*",
                "wget -q * -O /tmp/*",
                "jq *"
            ]
        },
        "read_file": {
            "enabled": true
        },
        "write_file": {
            "enabled": true
        },
        "list_dir": {
            "enabled": true
        },
        "web_fetch": {
            "enabled": true
        },
        "spawn": {
            "enabled": true
        },
        "subagent": {
            "enabled": true
        },
        "message": {
            "enabled": true
        },
        "mcp": {
            "enabled": true,
            "servers": {
                "gdrive": {
                    "enabled": false,
                    "command": "npx",
                    "args": [
                        "-y",
                        "@piotr-agier/google-drive-mcp"
                    ]
                },
                "gmail": {
                    "enabled": false,
                    "command": "npx",
                    "args": [
                        "-y",
                        "@gongrzhe/server-gmail-autoauth-mcp"
                    ]
                },
                "unity": {
                    "enabled": false,
                    "_comment": "Enable on Mac Mini with Unity Editor installed. Requires Unity 6+ with MCP package.",
                    "command": "npx",
                    "args": [
                        "-y",
                        "@unity/mcp-server"
                    ]
                }
            }
        },
        "tool_feedback": {
            "enabled": false
        }
    },
    "heartbeat": {
        "enabled": false
    }
