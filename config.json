{
    "version": 1,
    "session": {
        "dm_scope": "per-channel-peer"
    },
    "agents": {
        "defaults": {
            "model_name": "qwen3.5:4b",
            "workspace": "/opt/yeticlaw/openclaw/workspace",
            "restrict_to_workspace": false,
            "allow_read_outside_workspace": false,
            "max_tokens": 32768,
            "temperature": 0.7,
            "max_tool_iterations": 10,
            "tool_feedback": {
                "enabled": true,
                "max_args_length": 300
            },
            "summarize_message_threshold": 10,
            "summarize_token_percent": 75
        }
    },
    "model_list": [
        {
            "model_name": "qwen3.5:4b",
            "model": "openai/qwen3.5-4b-q4_k_m.gguf",
            "api_base": "http://127.0.0.1:8080/v1",
            "api_key": "none",
            "timeout": 120
        },
        {
            "model_name": "nano-banana-2",
            "model": "gemini/gemini-3.1-flash-image-preview",
            "api_key": "YOUR_GEMINI_API_KEY"
        }
    ],
    "channels": {
        "telegram": {
            "enabled": true,
            "token": "YOUR_TELEGRAM_BOT_TOKEN",
            "allow_from": [
                "YOUR_TELEGRAM_USER_ID"
            ]
        }
    },
    "gateway": {
        "host": "0.0.0.0",
        "port": 3002,
        "hot_reload": false
    },
    "tools": {
        "filter_sensitive_data": true,
        "filter_min_length": 8,
        "web": {
            "enabled": true,
            "duckduckgo": {
                "enabled": true,
                "max_results": 1
            }
        },
        "exec": {
            "enabled": true,
            "allow_remote": false,
            "enable_deny_patterns": false,
            "custom_allow_patterns": [
                "rclone copy *",
                "rclone mkdir *",
                "rclone ls *",
                "curl -s https://api.meshy.ai/*",
                "curl -s -X POST https://api.meshy.ai/*",
                "wget -q * -O /tmp/*",
                "jq *"
            ]
        },
        "read_file": {
            "enabled": true
        },
        "write_file": {
            "enabled": true
        },
        "list_dir": {
            "enabled": true
        },
        "web_fetch": {
            "enabled": true
        },
        "spawn": {
            "enabled": true
        },
        "subagent": {
            "enabled": true
        },
        "message": {
            "enabled": true
        },
        "mcp": {
            "enabled": true,
            "servers": {
                "gdrive": {
                    "enabled": false,
                    "command": "npx",
                    "args": [
                        "-y",
                        "@piotr-agier/google-drive-mcp"
                    ]
                },
                "gmail": {
                    "enabled": false,
                    "command": "npx",
                    "args": [
                        "-y",
                        "@gongrzhe/server-gmail-autoauth-mcp"
                    ]
                }
            }
        },
        "tool_feedback": {
            "enabled": false
        }
    },
    "heartbeat": {
        "enabled": false
    }
}