                "worldbuilder": "world-builder",
                "qatester": "qa-tester",
                "threejsdev": "threejs-dev",
                "aiconsultant": "ai-consultant",
                "emailwriter": "email-writer",
                "assetapprover": "asset-approver",
                "meshy": "meshy"
            }
        }
